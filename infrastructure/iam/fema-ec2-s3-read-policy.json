{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListProjectBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "dashboard/*",
            "forecasts/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadDashboardAndForecastFiles",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/dashboard/*",
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/forecasts/*"
      ]
    }
  ]
}
